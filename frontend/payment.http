### ========================================
### HƯỚNG DẪN LẤY TOKEN
### ========================================
# 1. Mở ứng dụng Frontend trong trình duyệt
# 2. Đăng nhập để lấy token
# 3. Mở DevTools (F12) → Console
# 4. Chạy lệnh: localStorage.getItem('dormstay_token')
# 5. Copy token vào biến @token ở trên (không cần "Bearer ", chỉ token)
#
# VD: @token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

### ========================================
### API: Confirm Payment - Xác nhận thanh toán đặt cọc
### ========================================
PUT {{baseUrl}}/payments/confirm/{{paymentLinkId}}
Authorization: Bearer {{token}}
Content-Type: application/json

### ========================================
### Ví dụ Chi Tiết
### ========================================
# Method: POST
# URL: http://localhost:4000/api/payments/confirm/1 
# 
# Headers:
#   Authorization: Bearer <your_auth_token>
#   Content-Type: application/json
#
# Response Success (200 OK):
# {
#   "success": true,
#   "data": {
#     "ma_yeu_cau_thue": 1,
#     "trang_thai": "DA_COC",
#     "ma_ho_so_khach_hang": 5,
#     "ma_phong": 10,
#     ...other fields
#   },
#   "message": "Payment confirmed successfully"
# }
#
# Response Error (400):
# {
#   "success": false,
#   "message": "Thiếu mã yêu cầu thuê"
# }
